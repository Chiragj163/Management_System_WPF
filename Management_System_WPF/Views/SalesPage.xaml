<Page x:Class="Management_System_WPF.Views.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="SalesPage"
      HorizontalAlignment="Center"
      d:DesignHeight="700" d:DesignWidth="1000"
      Background="Transparent" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#009688"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="DarkGreen"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#E0F2F1"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E53935"/>
        <SolidColorBrush x:Key="TextDark" Color="Black"/>
        <SolidColorBrush x:Key="TextLight" Color="#78909C"/>

        <Style TargetType="{x:Type Control}" x:Key="InputStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style TargetType="TextBox" x:Key="RoundedInputStyle" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryHover}"/>
                    </Trigger>
                    
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryHover}"/>
                        <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                        <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                    </Trigger>
                </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="RemoveButtonStyle">
        <Setter Property="Width" Value="25"/>
        <Setter Property="Height" Value="25"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFEBEE"/>
        <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        </Style>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-2" StrokeThickness="2" Stroke="{StaticResource PrimaryColor}" StrokeDashArray="1 2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

            <Border Background="#80F5F5F5"
                    CornerRadius="15"
                    Margin="0,0,20,20" 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">


                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="25,20,25,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ADD  SALE" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource TextDark}"/>
                        </StackPanel>

                        <Button Content="✖" 
        Width="30" Height="30"
        FontSize="16"
        HorizontalAlignment="Right"
                                ToolTip="Exit "
        Click="ExitSalePage_Click">

                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">

                                    <Setter Property="Foreground" Value="{StaticResource TextLight}"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>

                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                  
                    <Grid Grid.Row="1" Margin="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Buyer" FontWeight="Bold" Foreground="{StaticResource TextDark}" FontSize="16"   Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"  Margin="0,0,0,15"  >


                                <!-- Card container -->
                                <Border Height="30" Width="350"  Background="White"  CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3"  BlurRadius="10"   Opacity="0.16"/>
                                    </Border.Effect>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>

                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                    <Setter Property="Background" Value="#F4FAFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <!-- Modern ComboBox -->
                                    <ComboBox x:Name="cmbBuyer" 
          DisplayMemberPath="Name" 
          SelectedValuePath="BuyerId" 
          FontSize="14" ToolTip="Select Buyer Name" TabIndex="1" 
          FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="Black" 
          Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
           FocusVisualStyle="{StaticResource FocusVisual}"
          IsEditable="True" 
          IsTextSearchEnabled="False" 
          StaysOpenOnEdit="True" 
               KeyDown="ComboBox_KeyDown"                             KeyUp="SearchableComboBox_KeyUp"
         SelectionChanged="cmbBuyer_SelectionChanged">

                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>

                                        <ComboBox.Template>
                                            <ControlTemplate TargetType="ComboBox">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="PART_EditableTextBox" 
                         Grid.Column="0"
                         Margin="12,0,0,0" 
                         VerticalAlignment="Center" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         FontSize="14" 
                         FontFamily="Segoe UI" 
                         FontWeight="SemiBold" 
                         Foreground="Black"/>

                                                    <ToggleButton x:Name="PART_DropDownToggle" 
                             Grid.Column="0" 
              Grid.ColumnSpan="2"
                              Background="Transparent" 
                              BorderThickness="0" 
                              Focusable="False" 
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="Transparent"/>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>

                                                    <Path x:Name="Arrow" Grid.Column="1" Data="M0,0 L5,5 L10,0" Stroke="#3498DB" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>

                                                    <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                        <Border Background="White" CornerRadius="10" Margin="0,5,0,0" Padding="4" SnapsToDevicePixels="True">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Color="#AAAAAA" Opacity="0.28"/>
                                                            </Border.Effect>
                                                            <ScrollViewer MaxHeight="250">
                                                                <ItemsPresenter/>
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsDropDownOpen" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ComboBox.Template>

                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Padding" Value="10,6"/>
                                                <Setter Property="Width" Value="300"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBoxItem">
                                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="10" Padding="10,6" Margin="2,1">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EBF5FB"/>
                                                                    <Setter Property="Foreground" Value="#3498DB"/>
                                                                </Trigger>
                                                                
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3498DB"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Article / Item" FontWeight="Bold" Foreground="{StaticResource TextDark}" FontSize="16" ToolTip="Select Article Name" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15"   >

                                <!-- Card container -->
                                <Border Height="30" Width="350"  Background="White"  CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3"  BlurRadius="10"   Opacity="0.16"/>
                                    </Border.Effect>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>

                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                    <Setter Property="Background" Value="#F4FAFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <!-- Modern ComboBox -->
                                    <ComboBox x:Name="cmbItem" 
          DisplayMemberPath="Name" 
          SelectedValuePath="Id" 
          FontSize="14" ToolTip="Select Item" TabIndex="2" 
          FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="Black" 
          Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
          
          IsEditable="True" 
          IsTextSearchEnabled="False" KeyDown="ComboBox_KeyDown"
          StaysOpenOnEdit="True" 
                                      FocusVisualStyle="{StaticResource FocusVisual}"         
                                             KeyUp="SearchableComboBox_KeyUp"
SelectionChanged="cmbBuyer_SelectionChanged">

                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>

                                        <ComboBox.Template>
                                            <ControlTemplate TargetType="ComboBox">
                                                <Grid >
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="PART_EditableTextBox" 
                         Grid.Column="0"
                         Margin="12,0,0,0" 
                         VerticalAlignment="Center" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         FontSize="14" 
                         FontFamily="Segoe UI" 
                         FontWeight="SemiBold" 
                         Foreground="Black"/>

                                                    <ToggleButton x:Name="PART_DropDownToggle" 
                             Grid.Column="0" 
              Grid.ColumnSpan="2"
                              Background="Transparent" 
                              BorderThickness="0" 
                              Focusable="False" 
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="Transparent"/>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>

                                                    <Path x:Name="Arrow" Grid.Column="1" Data="M0,0 L5,5 L10,0" Stroke="#3498DB" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>

                                                    <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                        <Border Background="White" CornerRadius="10" Margin="0,5,0,0" Padding="4" SnapsToDevicePixels="True">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Color="#AAAAAA" Opacity="0.28"/>
                                                            </Border.Effect>
                                                            <ScrollViewer MaxHeight="250">
                                                                <ItemsPresenter/>
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsDropDownOpen" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ComboBox.Template>

                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Padding" Value="10,6"/>
                                                <Setter Property="Width" Value="300"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBoxItem">
                                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="10" Padding="10,6" Margin="2,1">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EBF5FB"/>
                                                                    <Setter Property="Foreground" Value="#3498DB"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3498DB"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Quantity" FontWeight="Bold" FontSize="16"  Foreground="{StaticResource TextDark}" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtQuantity"  FocusVisualStyle="{StaticResource FocusVisual}" Background="White" TabIndex="3"  ToolTip="Add Quantity"  KeyDown="txtQuantity_KeyDown" Style="{StaticResource RoundedInputStyle}" VerticalContentAlignment="Center" Height="30"/>

                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Date" FontWeight="Bold" Foreground="{StaticResource TextDark}" FontSize="16" Margin="0,0,0,5"/>
                                    <Border Background="#80F5F5F5"
        BorderBrush="#D0D0D0"
        BorderThickness="1"
        CornerRadius="10"
                                             FocusVisualStyle="{StaticResource FocusVisual}"
        Height="30"
        Margin="0,0,0,15">

                                        <DatePicker x:Name="dpSaleDate"
                SelectedDateFormat="Short"
                TabIndex="4"
                FontSize="14"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Background="Transparent"
                PreviewKeyDown="dpSaleDate_PreviewKeyDown">
                                            <DatePicker.CalendarStyle>
                                                <Style TargetType="Calendar">
                                                    <Setter Property="LayoutTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="1.4" ScaleY="1.4"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </DatePicker.CalendarStyle>


                                            <DatePicker.Resources>
                                                <Style TargetType="DatePickerTextBox">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="5,0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="DatePickerTextBox">
                                                                <Grid>
                                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                                    <TextBlock Text="Select Date" 
                                           Foreground="#999" 
                                           IsHitTestVisible="False"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </DatePicker.Resources>
                                        </DatePicker>
                                    </Border>


                                </StackPanel>
                            </Grid>

                            <Border Background="#80F5F5F5" CornerRadius="8" Padding="15" Margin="0,10,0,20" BorderBrush="#EEE" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="Calculate" 
                                            Grid.Column="0"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="#607D8B"
                                            Width="100" Height="35"
                                            TabIndex="5"
                                             FocusVisualStyle="{StaticResource FocusVisual}"
                                             ToolTip="Calculate Total"
                                            Click="Calculate_Click"/>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock Text="Total:" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextDark}" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="txtTotal" Text="0.00" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextDark}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Button Content="Add to Cart 🛒" 
                                    Style="{StaticResource PrimaryButton}"
                                    Height="45"
                                    Margin="0,0,0,10"
                                     FocusVisualStyle="{StaticResource FocusVisual}"
                                    TabIndex="6"
                                    Click="AddToCart_Click"/>

                            <Button Content="Save Entire Sale"
                                    x:Name="btnSaveSale"
                                    Height="40"
                                    TabIndex="7"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    FontWeight="Bold"
                                    FontSize="16"
                                    BorderThickness="2"
                                    FocusVisualStyle="{StaticResource FocusVisual}"
                                    KeyDown="btnSaveSale_KeyDown"
                                    Click="SaveSale_Click">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">

                                        <Border x:Name="border"
                    Background="#FAF9F9" 
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5"
                    BorderBrush="{StaticResource PrimaryColor}"
                    TextElement.Foreground="{StaticResource PrimaryColor}">

                                            <ContentPresenter HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                                                <Setter TargetName="border" Property="TextElement.Foreground" Value="{StaticResource SecondaryColor}"/>

                                                <Setter TargetName="border" Property="Background" Value="DarkGreen"/>

                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                                                <Setter TargetName="border" Property="TextElement.Foreground" Value="{StaticResource SecondaryColor}"/>
                                                <Setter TargetName="border" Property="Background" Value="DarkGreen"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                        

                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                        <Border Grid.Column="2" Background="#80F5F5F5" CornerRadius="10" BorderBrush="#EEE" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85*"/>
                                    <ColumnDefinition Width="463*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Background="#80F5F5F5" CornerRadius="10,10,0,0" Padding="15" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text=" 🛒 Cart" FontSize="20" FontWeight="ExtraBold"  Foreground="{StaticResource PrimaryColor}"/>
                                    </StackPanel>
                                </Border>

                                <DataGrid x:Name="dgCart"
                                          IsReadOnly="True"
                                          AutoGenerateColumns="False" 
                                          CanUserAddRows="False"
                                          CanUserResizeRows="False"
                                          CanUserReorderColumns="False"
                                          CanUserSortColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#EEE"
                                          BorderThickness="0"
                                          Background="#80F5F5F5"
                                          RowHeight="40"
                                          FontSize="14" Grid.ColumnSpan="2" Margin="0,51,0,0" Grid.RowSpan="2">

                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="10,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Buyer" Binding="{Binding BuyerName}"  Width="*"/>

                                        <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="*"/>
                                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                                        <DataGridTemplateColumn Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✖" 
            Style="{StaticResource RemoveButtonStyle}"
            Click="RemoveCartItem_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>