<Page x:Class="Management_System_WPF.Views.BuyerReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="BuyerReportPage"
      d:DesignHeight="750" d:DesignWidth="1100"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#009688"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#00796B"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#E0F2F1"/>
        <SolidColorBrush x:Key="TextDark" Color="#37474F"/>
        <SolidColorBrush x:Key="TextLight" Color="#78909C"/>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                         BorderBrush="{TemplateBinding BorderBrush}" 
                         BorderThickness="{TemplateBinding BorderThickness}" 
                         CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="#803498DB"
                CornerRadius="15"
                Margin="5"
                MaxWidth="2000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25,10,25,10" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock x:Name="txtBuyerName"
                                   Text="Buyer Name" 
                                   FontSize="30" 
                                   FontWeight="Bold" 
                                   Foreground="Black"/>
                    </StackPanel>
                </Grid>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Width="40" Height="40"
                        HorizontalAlignment="Left"
                        Margin="5,10,0,10"
                        ToolTip="Go Back"
                        Click="Back_Click">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                          Fill="Black"
                          Width="20" Height="20"
                          Stretch="Uniform"/>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="70,10,0,10" VerticalAlignment="Center">
                    <Button x:Name="btnPrevMonth"
                            Content="◄ Prev"
                            Style="{StaticResource SecondaryButton}"
                            Height="35" Width="80"
                            Click="PrevMonth_Click"/>

                    <TextBlock x:Name="txtMonthName"
                               Text="October 2025" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="Black"
                               VerticalAlignment="Center"
                               Margin="20,0"/>

                    <Button x:Name="btnNextMonth"
                            Content="Next ►"
                            Style="{StaticResource SecondaryButton}"
                            Height="35" Width="80"
                            Click="NextMonth_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Margin="0,10,30,10" Orientation="Horizontal">
                    <TextBlock Text="Category :" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Black" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbCategory" 
Width="150" 
Height="35"
Margin="0,0,30,0"
VerticalContentAlignment="Center"
FontSize="14"
SelectionChanged="CategoryFilter_Changed"/>
                    <StackPanel x:Name="ActionButtonsPanel" 
                Orientation="Horizontal" 
                Visibility="Collapsed">
                       
                        <Button Content="↩ Return"
            Style="{StaticResource PrimaryButton}"
            Background="#D32F2F"
            Height="35" Width="100"
            Margin="0,0,10,0"
            Click="Return_Click"/>
                        <Button Content="💵 Payment"
                Style="{StaticResource PrimaryButton}"
                Background="#FF9800"
                Height="35" Width="100"
                Margin="0,0,10,0"
                Click="Payment_Click"/>

                        <Button Content="🖨 Print"
                Style="{StaticResource PrimaryButton}"
                Background="#607D8B"
                Height="35" Width="100"
                Margin="0,0,10,0"
                Click="Print_Click"/>

                        <Button Content="📊 Excel"
                Style="{StaticResource PrimaryButton}"
                Background="#4CAF50"
                Height="35" Width="100"
                Margin="0,0,10,0"
                Click="ExportExcel_Click"/>
                       
                        <Button x:Name="btnFilter"
                Content="🔍 Filter"
                Style="{StaticResource PrimaryButton}"
                Height="35" Width="100"
                Margin="0,0,10,0"
                Click="Filter_Click"/>
                    </StackPanel>

                    <Button x:Name="btnMenu"
            Content="☰ Menu"
            Style="{StaticResource PrimaryButton}"
            Background="#34495E"
            Height="35" Width="100"
            ToolTip="Show/Hide Actions"
            Click="ToggleMenu_Click"/>

                </StackPanel>


                <Border Grid.Row="2" Margin="15,0,15,25" BorderThickness="0">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel VerticalAlignment="Top">

                            <Border CornerRadius="10,10,0,0" 
                    BorderBrush="#EEE" 
                    BorderThickness="0"
                    Background="#803498DB">

                                <DataGrid x:Name="dgBuyerReport"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="False"                                  
                          SelectionMode="Single"
                          SelectionUnit="Cell"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          Background="{StaticResource SecondaryColor}"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          MinRowHeight="32"
                          FontSize="14"
                          ColumnHeaderHeight="36"
                            BorderBrush="Black"              
                          BorderThickness="1">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                            <Setter Property="FontSize" Value="16"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="BorderThickness" Value="1,1,1,1"/>
                                            <Setter Property="BorderBrush" Value="Gray"/>
                                            <Setter Property="Padding" Value="6"/>
                                           
                                            <Setter Property="Margin" Value="1.5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="3"/>
                                            <Setter Property="BorderBrush" Value="Gray"/>
                                            <Setter Property="Margin" Value="1.5"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Date}" Value="Total Qty">
                                                    <Setter Property="Background" Value="#E6E6E6"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Date}" Value="Less Return">
                                                    <Setter Property="Background" Value="Red"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Date}" Value="Unit Price">
                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Date}" Value="Total Price">
                                                    <Setter Property="Background" Value="#26A69A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E0F2F1"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#B2DFDB"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </Border>

                            <Border
        CornerRadius="0,0,10,10" 
        >

                                <StackPanel >

                                    <Border Background="#004D40" CornerRadius="2" Margin="0,0,0,1" BorderBrush="Black" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Padding="10" BorderBrush="Black" BorderThickness="0,0,1,0">
                                                <TextBlock Text="Grand Total" Foreground="White" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <Border Grid.Column="1" Padding="10"  MinWidth="130">
                                                <TextBlock x:Name="txtTotalSales" Text="0.00" Foreground="White" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="PaymentPanel">
                                        <Border Background="#01889F" CornerRadius="2" Margin="0,0,0,1" BorderBrush="Black" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Padding="10" BorderBrush="Black" BorderThickness="0,0,1,0">
                                                <TextBlock Text="Less Amount" Foreground="White" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <Border Grid.Column="1" Padding="10" MinWidth="130">
                                                <TextBlock x:Name="txtPayment" Text="0.00" Foreground="White" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                        <Border Background="#BF360C" CornerRadius="2"  BorderBrush="Black" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Padding="10" BorderBrush="Black" BorderThickness="0,0,1,0">
                                                <TextBlock Text="Due Amount" Foreground="White" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <Border Grid.Column="1" Padding="10" >
                                                <TextBlock x:Name="txtBalance" Text="0.00" Foreground="White" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Border x:Name="FilterPanel"
                        Grid.Row="1" Grid.RowSpan="2"
                        Visibility="Collapsed"
                        Background="White"
                        BorderBrush="{StaticResource PrimaryColor}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Width="320"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,55,25,0">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
                    </Border.Effect>

                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Filter Sales" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                            <Button Content="✖" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="Gray" Click="Filter_Click"/>
                        </Grid>

                        <Button Content="This Month" Click="FilterThisMonth_Click" Style="{StaticResource SecondaryButton}" Height="40" Margin="0,0,0,10"/>
                        <Button Content="Last 6 Months" Click="FilterSixMonths_Click" Style="{StaticResource SecondaryButton}" Height="40" Margin="0,0,0,10"/>
                        <Button Content="This Year" Click="FilterYear_Click" Style="{StaticResource SecondaryButton}" Height="40" Margin="0,0,0,15"/>

                        <Separator Background="#EEE" Margin="0,0,0,15"/>

                        <TextBlock Text="Custom Range" FontWeight="SemiBold" Foreground="{StaticResource TextLight}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="dpFrom" Grid.Column="0" Height="35"/>
                            <DatePicker x:Name="dpTo" Grid.Column="2" Height="35"/>
                        </Grid>

                        <Button Content="Apply Filter" Click="FilterCustom_Click" Style="{StaticResource PrimaryButton}" Height="40"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Page>