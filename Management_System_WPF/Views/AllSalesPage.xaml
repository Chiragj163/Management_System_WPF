<Page x:Class="Management_System_WPF.Views.AllSalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="AllSalesPage"
      d:DesignHeight="1100" d:DesignWidth="1000"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#009688"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#00796B"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#E0F2F1"/>
        <SolidColorBrush x:Key="TextDark" Color="#37474F"/>
        <SolidColorBrush x:Key="TextLight" Color="#78909C"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E53935"/>
        <Style x:Key="CenteredTextColumn" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>


        <Style TargetType="{x:Type Control}" x:Key="FilterInputStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>


        <Border Background="#80F5F5F5"
                CornerRadius="15"
                Margin="5"
                MaxWidth="2000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

           
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25,20,25,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    

                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitle"
                                   Text="Sale List" 
                                   FontSize="26" 
                                  
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center"/>

                       
                    </StackPanel>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"  VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0">
                        <TextBlock Text="Category :" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Black" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbCategory" 
Width="145" 
Height="33"

VerticalContentAlignment="Center"
                              HorizontalAlignment="Right"
FontSize="14"
SelectionChanged="Filter_Changed"/>
                        </StackPanel>
                    <Button Content="🔍 Filter"
        
                            Padding="10,0"
         Height="35"
                            Width="80"
                            
         HorizontalAlignment="Right"
         Style="{StaticResource PrimaryButton}"
         Background="{StaticResource TextDark}"
         Click="ToggleFilter_Click"/>


                </Grid>
                <Button Grid.Column="1"
        Style="{StaticResource IconButtonStyle}"
        Width="40" Height="40"
                       Margin="5,10,0,10"
        HorizontalAlignment="Left"
                        
                       
        ToolTip="Go Back"
        Click="Back_Click">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
          Fill="{StaticResource TextDark}"
          Width="20" Height="20"
          Stretch="Uniform"/>
                </Button>



                <Border x:Name="FilterPanel" 
        Grid.Row="1" 
        Visibility="Collapsed"
        Background="White" 
        CornerRadius="10"
        Margin="25,0,25,20"
        Padding="20,15"
        BorderBrush="#EEE"
        BorderThickness="1">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Search Buyer / Item" 
                       FontSize="15" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextDark}" 
                       Margin="0,0,0,6"/>

                            <Grid >
                                <TextBox x:Name="txtSearch" 
                         Width="250" 
                         Style="{StaticResource FilterInputStyle}"
                         Padding="30,0,10,0"
                                         
                         TextChanged="Filter_Changed"/>

                                <Path Data="M15.5,14L14.71,14L14.43,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71L14,15.5L19,20.49L20.49,19L15.5,14ZM9.5,14C7.01,14 5,11.99 5,9.5C5,7.01 7.01,5 9.5,5C11.99,5 14,7.01 14,9.5C14,11.99 11.99,14 9.5,14Z"
                      Fill="{StaticResource TextDark}"
                      Width="16" Height="16"
                      Stretch="Uniform"
                      HorizontalAlignment="Left"
                      Margin="8,0,0,0" 
                      IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="From Date" 
                       FontSize="15" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextDark}" 
                       Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpFrom" 
                        Width="140"
                        Style="{StaticResource FilterInputStyle}"
                        SelectedDateChanged="Filter_Changed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="To Date" 
                       FontSize="15" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextDark}" 
                       Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpTo" 
                        Width="140"
                        Style="{StaticResource FilterInputStyle}"
                        SelectedDateChanged="Filter_Changed"/>
                        </StackPanel>

                        <Button Grid.Column="4"
                VerticalAlignment="Bottom"
                Click="ClearFilter_Click"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Height="40">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                  Fill="{StaticResource DangerColor}"
                                  Width="14" Height="14"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                                            <TextBlock Text="Reset Filters" 
                                       Foreground="{StaticResource DangerColor}" 
                                       FontWeight="SemiBold"
                                       FontSize="15"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>
                </Border>
                <Border Grid.Row="2" 
                        Margin="25,10,25,25"
                        Background="#80F5F5F5" 
                        CornerRadius="10" 
                        BorderBrush="#EEE" 
                        BorderThickness="0">

                    <DataGrid x:Name="dgSales"
          Grid.Row="2"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          FrozenColumnCount="1"                         
          GridLinesVisibility="All"
          HorizontalGridLinesBrush="Transparent"
          VerticalGridLinesBrush="Transparent"
          BorderThickness="0"
                
          Background="Transparent"
          FontSize="19"
          ColumnHeaderHeight="50"
          AlternationCount="2"
            FontFamily="Arial"                
          VerticalScrollBarVisibility="Auto"
          ColumnWidth="*">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="1,1,1,1"/>
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="Margin" Value="1.5"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="MinHeight" Value="65"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="1.5"/>
                                <Setter Property="BorderBrush" Value="Black"/>
                                
                                <Setter Property="BorderThickness" Value="1,1,1,1"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" 
                     Binding="{Binding SaleDate, StringFormat=dd/MM/yyyy}" 
                     Width="*"
                     ElementStyle="{StaticResource CenteredTextColumn}"
                     FontWeight="Bold"
                    />

                            <DataGridTextColumn Header="Customer Name"
                            Binding="{Binding BuyerName}"
                            Width="*" 
                            ElementStyle="{StaticResource CenteredTextColumn}"
                            FontWeight="Bold"
                           />

                            <DataGridTextColumn Header="Article"
                            Binding="{Binding ItemName}"
                            Width="*"
                                                 FontWeight="Bold"
                            ElementStyle="{StaticResource CenteredTextColumn}"/>

                            <DataGridTextColumn Header="Quantity"
                            Binding="{Binding Quantity}"
                            Width="*"
                            FontWeight="Bold"
                            ElementStyle="{StaticResource CenteredTextColumn}"/>

                            <DataGridTextColumn Header="Amount"
                            Binding="{Binding Amount}"
                            Width="*"
                            ElementStyle="{StaticResource CenteredTextColumn}"
                            FontWeight="Bold"
                           />
                           

                            <DataGridTemplateColumn Header="Action" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="36" Height="36"
                            Background="#E0F7FA"
                            Cursor="Hand"
                            Click="Options_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                        <Path Data="M12,2 L14,4 L6,12 L4,12 L4,10 Z"
                                          Fill="{StaticResource PrimaryColor}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="45"/>
                                <Setter Property="MinHeight" Value="70"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                
                                <Setter Property="SnapsToDevicePixels" Value="True"/>
                               
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#FAFAFA"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1F8E9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                    </DataGrid>

                </Border>
                

            </Grid>
            
        </Border>
    </Grid>
</Page>