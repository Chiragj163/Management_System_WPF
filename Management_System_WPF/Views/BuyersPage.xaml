<Page x:Class="Management_System_WPF.Views.BuyersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="BuyersPage"
       HorizontalAlignment="Center"
      d:DesignHeight="700" d:DesignWidth="1000"
      Background="Transparent" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="DangerColor" Color="#E53935"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#009688"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#00796B"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#E0F2F1"/>
        <SolidColorBrush x:Key="TextDark" Color="Black"/>
        <SolidColorBrush x:Key="TextLight" Color="#78909C"/>

        <Style TargetType="{x:Type Control}" x:Key="InputStyle">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBox" x:Key="RoundedInputStyle" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>


        <Border Background="#80F5F5F5"
                CornerRadius="15"
                Margin="0,0,0,20"
               
                HorizontalAlignment="Center"
                VerticalAlignment="Center">


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25,20,25,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ADD NEW BUYER" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextDark}"/>
                    </StackPanel>

                    <Button Content="✖" 
Width="30" Height="30"
FontSize="16"
HorizontalAlignment="Right"
                            ToolTip="Exit"
 Click="ExitBuyerPage_Click">

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">

                                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>

                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>

                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                   
                </Grid>

                

                <Grid Grid.Row="1" Margin="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">


                        <TextBlock Text="Buyer Name" FontWeight="Bold"  FontSize="16" Foreground="{StaticResource TextDark}" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtBuyerName"   Height="30" Background="White"   ToolTip="Add Buyer Name" Style="{StaticResource RoundedInputStyle}" Text=""/>

                        <Button x:Name="btnSave"
                                Content="Save Buyer"
                                Style="{StaticResource PrimaryButton}"
                                Height="45"  IsDefault="True"
                                Margin="0,10,0,0"
                                Click="SaveBuyer_Click"/>

                        
                    </StackPanel>

                    <Border Grid.Column="2" 
                            Background="White" 
                            CornerRadius="10" 
                            BorderBrush="#EEE" 
                            BorderThickness="1">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource SecondaryColor}" CornerRadius="10,10,0,0" Padding="15">
                                
                               
                                    <Grid>
                                        

                                       

                                        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="15" 
                Padding="10,5" 
                                                HorizontalAlignment="Right"
                Width="200"
                BorderBrush="#B2DFDB"
                BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 🔍 Icon -->
                                            <Path Data="M15.5,14L14.71,13.21C15.5,12 16,10.5 16,9C16,5.13 12.87,2 9,2C5.13,2 2,5.13 2,9C2,12.87 5.13,16 9,16C10.5,16 12,15.5 13.21,14.71L14,15.5V16L19,21L21,19L16,14M9,14C6.24,14 4,11.76 4,9C4,6.24 6.24,4 9,4C11.76,4 14,6.24 14,9C14,11.76 11.76,14 9,14Z"
          Fill="{StaticResource TextLight}"
          Width="16" Height="16"
          Stretch="Uniform"
          Margin="0,0,8,0"/>

                                            <!-- TextBox -->
                                            <Grid Grid.Column="1">
                                               
                                                    <!-- TextBox -->
                                                    <TextBox x:Name="txtSearchBuyer"
             BorderThickness="0"
             Background="White"
             VerticalContentAlignment="Center"
             FontSize="14"
             Foreground="{StaticResource TextDark}"
             CaretBrush="Black"
             ToolTip="Search Name"
             TextChanged="txtSearchBuyer_TextChanged"/>

                                                    <!-- Placeholder -->
                                                    <TextBlock Text="Search..."
               Margin="6,0,0,0"
               VerticalAlignment="Center"
               Foreground="{StaticResource TextLight}"
               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearchBuyer}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                            </Grid>

                                    </Border>
                                    </Grid>
                               
                            </Border>

                            <DataGrid x:Name="dgBuyers"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EEE"
                                      BorderThickness="0"
                                      Background="White"
                                      RowHeight="50"
                                      FontSize="15"
                                      VerticalScrollBarVisibility="Auto">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                                        <Setter Property="Padding" Value="15,10"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#EEE"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="15,0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="#" 
                                                        Binding="{Binding SerialNumber}" 
                                                        Width="60"
                                                        Foreground="{StaticResource TextLight}"/>

                                    <DataGridTextColumn Header="Buyer Name" 
                                                        Binding="{Binding Name}" 
                                                        Width="*"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource TextDark}"/>

                                    <DataGridTemplateColumn Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Width="36" Height="36"
                                                        Background="#E0F7FA"
                                                        Cursor="Hand"
                                                        Click="Options_Click">

                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                                <Path Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25z M20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z"
                                                                      Fill="{StaticResource PrimaryColor}"
                                                                      Width="16" Height="16"
                                                                      Stretch="Uniform"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>