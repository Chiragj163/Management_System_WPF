<Window x:Class="Management_System_WPF.Views.ReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Return" Height="300" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">

    <Border Background="White" CornerRadius="10" BorderBrush="#E53935" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="Return Item" FontWeight="Bold" FontSize="20" Foreground="#E53935" Margin="0,0,0,20"/>

            <TextBlock Text="Select Article" Foreground="#555" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbItems" Height="35" FontSize="14" Margin="0,0,0,15" DisplayMemberPath="ItemName" SelectedValuePath="ItemName"/>

            <TextBlock Text="Quantity to Return" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="txtQty" Height="35" FontSize="16" VerticalContentAlignment="Center" Padding="5" BorderBrush="#CFD8DC" BorderThickness="1"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Width="80" Height="35" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Margin="0,0,10,0"/>
                <Button Content="Confirm Return" Click="Save_Click" Width="120" Height="35" Background="#E53935" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>