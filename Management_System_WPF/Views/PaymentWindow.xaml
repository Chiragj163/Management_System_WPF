<Window x:Class="Management_System_WPF.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Payment" Height="200" Width="320"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">

    <Border Background="White" CornerRadius="10" BorderBrush="#009688" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="Enter Payment Amount" FontWeight="Bold" FontSize="18" Foreground="#009688" Margin="0,0,0,15"/>

            <TextBox x:Name="txtAmount" Height="40" FontSize="18" VerticalContentAlignment="Center" 
                     Padding="5" BorderBrush="#CFD8DC" BorderThickness="1"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Width="80" Height="35" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Margin="0,0,10,0"/>
                <Button Content="Save" Click="Save_Click" Width="80" Height="35" Background="#009688" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>