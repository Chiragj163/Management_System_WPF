<Window x:Class="Management_System_WPF.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Credentials" Height="550" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#009688"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#00796B"/>
        <SolidColorBrush x:Key="TextDark" Color="#37474F"/>
        <SolidColorBrush x:Key="TextLight" Color="#90A4AE"/>
        <SolidColorBrush x:Key="InputBg" Color="#F7F9FA"/>

        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="White" Margin="15" BorderBrush="{StaticResource PrimaryColor}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.25" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="15,15,15,0">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource InputBg}" Margin="0,0,10,0">
                        <TextBlock Text="🛡️" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Security Settings" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                        <TextBlock Text="Update your credentials" FontSize="12" Foreground="{StaticResource TextLight}"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕" Click="Cancel_Click"
                        Style="{StaticResource CloseBtnStyle}"
                        Foreground="#90A4AE" FontSize="14" FontWeight="Bold"
                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Width="30" Height="30"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="30">

                <TextBlock Text="Verification" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

                <TextBlock Text="Current Password (Required)" Foreground="{StaticResource TextDark}" FontSize="13" FontWeight="SemiBold" Margin="5,0,0,5"/>
                <Border Background="{StaticResource InputBg}" CornerRadius="8" Height="40" Padding="10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                              Fill="#E57373" Width="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <PasswordBox x:Name="txtOldPass" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14"/>
                    </Grid>
                </Border>

                <Separator Margin="0,20,0,20" Background="#EEE"/>

                <TextBlock Text="New Credentials" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

                <TextBlock Text="New Username" Foreground="{StaticResource TextLight}" FontSize="13" Margin="5,0,0,5"/>
                <Border Background="{StaticResource InputBg}" CornerRadius="8" Height="40" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                              Fill="{StaticResource TextLight}" Width="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <TextBox x:Name="txtNewUser" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14"/>
                    </Grid>
                </Border>

                <TextBlock Text="New Password" Foreground="{StaticResource TextLight}" FontSize="13" Margin="5,15,0,5"/>
                <Border Background="{StaticResource InputBg}" CornerRadius="8" Height="40" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M7,14A2,2 0 0,1 5,12A2,2 0 0,1 7,10A2,2 0 0,1 9,12A2,2 0 0,1 7,14M12.65,10C11.83,7.67 9.61,6 7,6A6,6 0 0,0 1,12A6,6 0 0,0 7,18C9.61,18 11.83,16.33 12.65,14H17V18H21V14H23V10H12.65Z"
                              Fill="{StaticResource TextLight}" Width="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <PasswordBox x:Name="txtNewPass" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14"/>
                    </Grid>
                </Border>

                <Grid Margin="0,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click"
                            Height="40" Background="White" Foreground="{StaticResource TextLight}"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2" Content="Update" Click="Save_Click"
                            Height="40" Background="{StaticResource PrimaryColor}" Foreground="White"
                            FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                        <Setter TargetName="bdr" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="#009688"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>