<Window x:Class="Management_System_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Factory Management System"
        WindowState="Maximized"
        WindowStyle="None"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" 
                      CornerRadius="0" 
                      CaptionHeight="0"
                      ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Viewbox Stretch="Uniform">

        <Grid Width="1600" Height="900" x:Name="RootGrid">


            <Grid.Background>

                <ImageBrush ImageSource="/Assets/bg.jpg" Stretch="UniformToFill"/>

            </Grid.Background>


            <Grid x:Name="MainLayout">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="400"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Grid x:Name="TopBarGrid"
      Grid.ColumnSpan="2"
      Height="70"
      VerticalAlignment="Top"
      Background="Transparent"
      MouseLeftButtonDown="TopBar_MouseDown">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock  Grid.Column="1" x:Name="txtDate"
               Margin="20,0,0,0"
               VerticalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               Foreground="White" />

                    <Grid Grid.Column="0" Margin="20,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <Button x:Name="btnSettings"
            Width="45" Height="45"
            Background="#30FFFFFF"
            BorderThickness="0"
            Cursor="Hand"
            Click="Settings_Click"
            ToolTip="Settings">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="25">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,13L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                          Fill="White"
                          Width="24" Height="24"
                          Stretch="Uniform"
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="#50FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                            <Button.ContextMenu>
                                <ContextMenu>
                                    <ContextMenu.Template>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="White" CornerRadius="8" Padding="5" BorderBrush="#EEEEEE" BorderThickness="1">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.1" Color="Black"/>
                                                </Border.Effect>
                                                <StackPanel IsItemsHost="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContextMenu.Template>

                                    <ContextMenu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Padding" Value="15,10"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="MenuItem">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center"/>
                                                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ContextMenu.Resources>

                                    <MenuItem Header="Change Background" Click="ChangeBackground_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="🖼️" FontSize="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Change Password" Click="Reset_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="🔒" FontSize="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator Background="#EEEEEE" Margin="5"/>

                                    <MenuItem Header="Logout" Click="Logout_Click" Foreground="#D32F2F" FontWeight="SemiBold">
                                        <MenuItem.Icon>
                                            <TextBlock Text="⏻" FontSize="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="txtTime"
               Grid.Column="2"
               Margin="0,0,20,0"
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               Foreground="White" />

                    <StackPanel Grid.Column="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,10,0">
                        <Button Content="—" Width="40" Height="40" FontSize="22" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Minimize_Click"/>
                        <Button Content="▢" Width="40" Height="40" FontSize="18" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Maximize_Click"/>
                        <Button Content="✖" Width="40" Height="40" FontSize="18" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Exit_Click"/>
                    </StackPanel>

                </Grid>


                <Border x:Name="SideMenu"
                        Grid.Column="0"
                        Margin="0,70,0,0"
                        Padding="20">

                    <StackPanel>

                        <StackPanel.Resources>
                            <Style x:Key="MenuButton" TargetType="Button">
                                <Setter Property="Height" Value="120"/>
                                <Setter Property="Margin" Value="0,20,0,0"/>
                                <Setter Property="FontSize" Value="25"/>
                                <Setter Property="Background" Value="#FF3CB4A7"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="20"
                                                    Padding="20,0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                        <Button Content="Sales" Style="{StaticResource MenuButton}" Click="Sales_Click"/>
                        <Button Content="Inventory" Style="{StaticResource MenuButton}" Click="Inventory_Click"/>
                        <Button Content="Buyers" Style="{StaticResource MenuButton}" Click="Buyers_Click"/>
                        <Button Content="Reports" Style="{StaticResource MenuButton}" Click="Reports_Click"/>
                       
                        <Button Content="All Sales" Style="{StaticResource MenuButton}" Click="AllSales_Click"/>

                    </StackPanel>
                </Border>

                <Frame x:Name="MainFrame"
                       Grid.Column="1"
                       Margin="0,70,0,0"
                       NavigationUIVisibility="Hidden"/>

            </Grid>

        </Grid>
    </Viewbox>

</Window>